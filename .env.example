MONGO_URI=mongodb+srv://...
TELEGRAM_TOKEN=...
TELEGRAM_CHAT_ID=...

# Render (auto-set by Render, only needed for webhook mode)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# WEBHOOK_SECRET=random-string
# TRIGGER_SECRET=random-string

# Telegram Mini App (Web App)
# WEB_APP_URL: HTTPS URL where the React frontend is hosted (GitHub Pages).
# When set, scheduled reviews send a notification with a "Start Review"
# button that opens the Mini App. Unset to use the message-per-card flow.
# WEB_APP_URL=https://<user>.github.io/arabic_tutor_bot/
# WEB_APP_ORIGIN: CORS allow-origin for /api/* (the frontend's origin only).
# WEB_APP_ORIGIN=https://<user>.github.io
